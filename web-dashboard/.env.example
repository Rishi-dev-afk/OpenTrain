# ── Local development only ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# Never commit .env.local to git.

# URL of the coordinator for local dev.
# In production (Vercel), leave this unset — the /api rewrite proxy is used instead.
COORDINATOR_URL=http://localhost:8000

# Optional: override the API base used by the browser.
# Leave unset in production. Set only if you need to talk directly to Render
# from the browser (bypassing the Vercel proxy).
# NEXT_PUBLIC_COORDINATOR_URL=https://opentrain-coordinator.onrender.com
